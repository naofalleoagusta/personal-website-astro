---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../sections/HeroSection';
import TechStackSection from '../sections/TechStackSection';
import ExperienceSection from '../sections/ExperienceSection';
import BlogPreviewSection from '../sections/BlogPreviewSection';
import { getCollection } from 'astro:content';
import experiencesJson from '../data/experiences.json';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestPosts = sortedPosts.slice(0, 3);

const experienceData = experiencesJson;
---

<Layout>
  <HeroSection client:load />
  <TechStackSection client:visible />
  <ExperienceSection experiences={experienceData} client:visible />
  <BlogPreviewSection posts={latestPosts} client:visible />
</Layout>
