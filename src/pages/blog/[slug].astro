---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import TableOfContents from '../../components/TableOfContents';
import { Calendar, Clock, ArrowLeft, ArrowRight } from 'lucide-react';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.data.permalink },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Get prev/next posts for navigation
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const currentIndex = sortedPosts.findIndex((p) => p.data.permalink === post.data.permalink);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

const formatDate = (date: Date) => {
  return new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<Layout
  title={`${post.data.title} | Naofal Leo Agusta`}
  description={post.data.description}
  ogImage={post.data.ogImage ?? undefined}
  canonical={`https://naofalleoagusta.xyz/blog/${post.data.permalink}`}
  jsonLd={[
    {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: post.data.title,
      description: post.data.description,
      datePublished: post.data.date.toISOString(),
      author: {
        '@type': 'Person',
        name: 'Naofal Leo Agusta',
        url: 'https://naofalleoagusta.xyz',
      },
      publisher: {
        '@type': 'Person',
        name: 'Naofal Leo Agusta',
        url: 'https://naofalleoagusta.xyz',
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': `https://naofalleoagusta.xyz/blog/${post.data.permalink}`,
      },
      keywords: (post.data.tags ?? []).join(', '),
    },
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://naofalleoagusta.xyz',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Blog',
          item: 'https://naofalleoagusta.xyz/blog',
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: post.data.title,
        },
      ],
    },
  ]}
>
  <article class="section-padding px-4 sm:px-6 lg:px-8 pt-28">
    <div class="max-w-[1400px] mx-auto">
      {/* Hero Block */}
      <header class="mb-12 pb-8 border-b-4 border-[var(--color-accent)]">
        {/* Meta bar */}
        <div class="flex flex-wrap items-center gap-3 text-xs text-[var(--color-text-secondary)] mb-6">
          <span class="flex items-center gap-1 font-mono">
            <Calendar className="w-3 h-3" />
            {formatDate(post.data.date)}
          </span>
          <span class="w-1 h-1 bg-[var(--color-text-secondary)]" />
          <span class="flex items-center gap-1 font-mono">
            <Clock className="w-3 h-3" />
            {post.data.readingTime}
          </span>
          {(post.data.tags || []).length > 0 && (
            <>
              <span class="w-1 h-1 bg-[var(--color-text-secondary)]" />
              <div class="flex gap-2">
                {(post.data.tags || []).map((tag) => (
                  <a
                    href={`/blog?tag=${tag}`}
                    class="px-2 py-0.5 text-[10px] font-mono border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
                  >
                    {tag}
                  </a>
                ))}
              </div>
            </>
          )}
        </div>

        {/* Massive title */}
        <h1 class="font-display font-bold text-[var(--color-text-primary)] leading-[0.95] tracking-tight max-w-4xl" style="font-size: clamp(2rem, 5.5vw, 4rem);">
          {post.data.title}
        </h1>
      </header>

      {/* Content area with sidebar */}
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
        {/* TOC sidebar */}
        <div class="lg:col-span-3">
          <TableOfContents headings={headings} client:load />
        </div>

        {/* Main content */}
        <div class="lg:col-span-9">
          <div class="prose-custom max-w-[720px]">
            <Content />
          </div>

          {/* Author block */}
          <div class="mt-16 p-6 border-2 border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
            <p class="text-xs font-mono uppercase tracking-widest text-[var(--color-text-secondary)] mb-2">
              Written by
            </p>
            <p class="font-display font-bold text-lg text-[var(--color-text-primary)] mb-1">
              Naofal Leo Agusta
            </p>
            <a
              href="mailto:naofal.leo.agusta98@gmail.com"
              class="text-sm text-[var(--color-accent)] hover:underline"
            >
              naofal.leo.agusta98@gmail.com
            </a>
          </div>

          {/* Tags */}
          {(post.data.tags || []).length > 0 && (
            <div class="mt-8">
              <p class="text-xs font-mono uppercase tracking-widest text-[var(--color-text-secondary)] mb-3">
                Tagged
              </p>
              <div class="flex flex-wrap gap-2">
                {(post.data.tags || []).map((tag) => (
                  <a
                    href={`/blog?tag=${tag}`}
                    class="px-3 py-1.5 text-sm font-mono border-2 border-[var(--color-border)] text-[var(--color-text-secondary)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
                  >
                    {tag}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>

      {/* Next / Prev Navigation */}
      <nav class="mt-20 border-t-2 border-[var(--color-border)] pt-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
          {/* Previous */}
          <a
            href={prevPost ? `/blog/${prevPost.data.permalink}` : '/blog'}
            class={`group block p-6 sm:p-8 border-b-2 md:border-b-0 md:border-r-2 border-[var(--color-border)] hover:bg-[var(--color-bg-secondary)] transition-colors ${!prevPost ? 'opacity-50 pointer-events-none' : ''}`}
          >
            <span class="text-xs font-mono uppercase tracking-widest text-[var(--color-text-secondary)] mb-3 block flex items-center gap-1">
              <ArrowLeft className="w-3 h-3" />
              Previous Post
            </span>
            <span class="font-display font-bold text-lg sm:text-xl text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors line-clamp-2">
              {prevPost ? prevPost.data.title : 'Back to Blog'}
            </span>
          </a>

          {/* Next */}
          <a
            href={nextPost ? `/blog/${nextPost.data.permalink}` : '/blog'}
            class={`group block p-6 sm:p-8 text-left md:text-right hover:bg-[var(--color-bg-secondary)] transition-colors ${!nextPost ? 'opacity-50 pointer-events-none' : ''}`}
          >
            <span class="text-xs font-mono uppercase tracking-widest text-[var(--color-text-secondary)] mb-3 block flex items-center gap-1 md:justify-end">
              Next Post
              <ArrowRight className="w-3 h-3" />
            </span>
            <span class="font-display font-bold text-lg sm:text-xl text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors line-clamp-2">
              {nextPost ? nextPost.data.title : 'Back to Blog'}
            </span>
          </a>
        </div>
      </nav>

      {/* Back to blog */}
      <div class="mt-10 text-center">
        <a href="/blog" class="brutalist-button gap-2 text-sm">
          <ArrowLeft className="w-4 h-4" />
          All Posts
        </a>
      </div>
    </div>
  </article>
</Layout>

<script>
  // Add copy buttons to all code blocks
  document.querySelectorAll('pre').forEach((pre) => {
    const button = document.createElement('button');
    button.className = 'copy-code-btn';
    button.innerHTML = 'Copy';
    button.setAttribute('aria-label', 'Copy code');
    
    const wrapper = document.createElement('div');
    wrapper.className = 'code-block-wrapper';
    wrapper.style.position = 'relative';
    
    pre.parentNode?.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);
    wrapper.appendChild(button);
    
    button.addEventListener('click', async () => {
      const code = pre.querySelector('code');
      if (code) {
        await navigator.clipboard.writeText(code.textContent || '');
        button.innerHTML = 'Copied!';
        button.classList.add('copied');
        setTimeout(() => {
          button.innerHTML = 'Copy';
          button.classList.remove('copied');
        }, 2000);
      }
    });
  });
</script>

<style is:global>
  .code-block-wrapper {
    position: relative;
  }
  .code-block-wrapper pre {
    position: relative;
  }
  .copy-code-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .code-block-wrapper:hover .copy-code-btn {
    opacity: 1;
  }
  .copy-code-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .copy-code-btn.copied {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>

<style is:global>
  .prose-custom {
    color: var(--color-text-primary);
  }
  .prose-custom h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.75rem;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
    position: relative;
  }
  .prose-custom h2::before {
    content: '';
    position: absolute;
    left: -1.5rem;
    top: 0.4rem;
    width: 0.5rem;
    height: 0.5rem;
    background: var(--color-accent);
  }
  @media (max-width: 1024px) {
    .prose-custom h2::before {
      display: none;
    }
  }
  .prose-custom h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.35rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
  }
  .prose-custom h4 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-text-primary);
  }
  .prose-custom p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }
  .prose-custom a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 500;
  }
  .prose-custom a:hover {
    color: var(--color-accent-secondary);
  }
  .prose-custom ul, .prose-custom ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  .prose-custom li {
    margin-bottom: 0.5rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
  .prose-custom ul li {
    list-style-type: disc;
  }
  .prose-custom ol li {
    list-style-type: decimal;
  }
  .prose-custom strong {
    font-weight: 700;
    color: var(--color-text-primary);
  }
  /* Pull quotes — brutalist blockquote */
  .prose-custom blockquote {
    position: relative;
    border-left: 4px solid var(--color-accent);
    padding: 1.5rem 1.5rem 1.5rem 2rem;
    margin: 2.5rem 0;
    background: var(--color-bg-secondary);
  }
  .prose-custom blockquote p {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-style: italic;
    color: var(--color-text-primary);
    margin-bottom: 0;
    line-height: 1.5;
  }
  .prose-custom blockquote p:last-child {
    margin-bottom: 0;
  }
  .prose-custom pre {
    background: var(--color-code-bg);
    border: 2px solid var(--color-border);
    padding: 1.25rem;
    overflow-x: auto;
    margin: 2rem 0;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.7;
    position: relative;
  }
  .prose-custom pre::before {
    content: '>';
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    color: var(--color-accent);
    font-weight: bold;
  }
  .prose-custom pre code {
    background: transparent;
    padding: 0;
    color: inherit;
    display: block;
    padding-left: 1.5rem;
  }
  .prose-custom code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-bg-secondary);
    padding: 0.15rem 0.4rem;
    color: var(--color-accent);
  }
  .prose-custom img {
    max-width: 100%;
    height: auto;
    border: 2px solid var(--color-border);
    margin: 2rem 0;
  }
  .prose-custom hr {
    border: none;
    border-top: 2px solid var(--color-border);
    margin: 2.5rem 0;
  }
  /* Terminal-style code blocks */
  .prose-custom pre {
    background: #1a1614;
    border: 2px solid var(--color-border);
    border-radius: 0;
  }
</style>
