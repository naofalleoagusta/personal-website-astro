---
import Layout from '../layouts/Layout.astro';
import { ArrowLeft } from 'lucide-react';
---

<Layout
  title="404 - Page Not Found | Naofal Leo Agusta"
  description="The page you are looking for does not exist."
>
  <section class="min-h-[70dvh] flex flex-col items-center justify-center px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-lg">
      <div class="mb-6">
        <span class="font-display font-bold text-[8rem] sm:text-[12rem] leading-none text-[var(--color-text-primary)] select-none">
          4<span class="text-[var(--color-accent)]">0</span>4
        </span>
      </div>
      <h1 class="font-display font-bold text-2xl sm:text-3xl text-[var(--color-text-primary)] mb-4">
        Page Not Found
      </h1>
      <p class="text-base text-[var(--color-text-secondary)] mb-8">
        The page you're looking for doesn't exist or has been moved. 
        Let's get you back on track.
      </p>
      <a href="/" class="brutalist-button gap-2">
        <ArrowLeft className="w-4 h-4" />
        Back to Home
      </a>
    </div>
  </section>
</Layout>
