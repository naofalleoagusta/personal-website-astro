---
import type { ImageMetadata } from 'astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string | ImageMetadata;
  canonical?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { 
  title = 'Naofal Leo Agusta | Software Engineer',
  description = 'Personal website and blog of Naofal Leo Agusta, a software engineer based in Palembang, Indonesia.',
  ogImage,
  canonical,
  jsonLd
} = Astro.props;

const defaultOgImage = '/images/og-default.png';
const ogImageSrc = typeof ogImage === 'string' 
  ? ogImage 
  : ogImage?.src ?? defaultOgImage;

const siteUrl = 'https://naofalleoagusta.xyz';
const fullOgImage = ogImageSrc.startsWith('http') ? ogImageSrc : `${siteUrl}${ogImageSrc}`;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content="Naofal Leo Agusta" />
<link rel="canonical" href={canonical || Astro.url.href} />

<!-- Theme color — adapts to current mode -->
<meta name="theme-color" content="#FAF6F1" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#1A1614" media="(prefers-color-scheme: dark)" />

<!-- Favicon -->
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title="Naofal Leo Agusta" href="/rss.xml" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Naofal Leo Agusta" />
<meta property="og:url" content={Astro.url.href} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@naofalleoagusta" />
<meta name="twitter:creator" content="@naofalleoagusta" />
<meta property="twitter:url" content={Astro.url.href} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={fullOgImage} />

<!-- Fonts preload -->
<link rel="preconnect" href="https://api.fontshare.com" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- JSON-LD structured data -->
{jsonLd && (
  <script
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
  />
)}

<!-- Theme script (no flash) -->
<script is:inline>
  (function() {
    const theme = localStorage.getItem('theme') || 'light';
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    }
  })();
</script>
